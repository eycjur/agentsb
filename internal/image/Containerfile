# Ref: https://hub.docker.com/layers/docker/sandbox-templates/shell/images/sha256-f67952703094538ead6f09d9d6efaf58997719bfe5b7f9021b458f78d09d7cdb
FROM docker/sandbox-templates:shell

ARG YAZI_VERSION=v26.5.6

ENV DEBIAN_FRONTEND=noninteractive
ENV IS_SANDBOX=1

USER root

# 以下のパッケージはベースイメージに含まれている
# ca-certificates curl git jq less make nodejs python3 sudo
#
# sbx のプロキシは archive.ubuntu.com:80 への dial に失敗することがあるため、HTTPS に切り替える。
RUN sed -i \
      -e 's|http://archive.ubuntu.com/ubuntu/|https://archive.ubuntu.com/ubuntu/|g' \
      -e 's|http://security.ubuntu.com/ubuntu/|https://security.ubuntu.com/ubuntu/|g' \
      /etc/apt/sources.list.d/ubuntu.sources && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      fzf gh python-is-python3 vim zsh && \
    npm install -g @anthropic-ai/claude-code @openai/codex hunkdiff && \
    UV_TOOL_DIR=/usr/local/share/uv/tools UV_TOOL_BIN_DIR=/usr/local/bin \
      uv tool install yazi-bin==26.5.6 && \
    chsh -s /bin/zsh agent && \
    rm -rf /var/lib/apt/lists/*

# 認証情報ファイルは `sbx cp` でサンドボックス作成後にコピーする
# （internal/home 参照）。コピー先の親ディレクトリだけ先に用意しておく。
RUN mkdir -p /home/agent/.claude /home/agent/.codex && \
    chown -R agent:agent /home/agent/.claude /home/agent/.codex

USER agent
